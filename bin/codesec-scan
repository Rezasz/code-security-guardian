#!/usr/bin/env python3
"""
codesec-scan — Code Security Guardian scanner
Regex-based static analysis across all stacks. Stdlib only, Python 3.8+.
Author: Reza Sahebozamani <sahebzamanii@gmail.com>
"""

import argparse
import fnmatch
import hashlib
import json
import os
import re
import subprocess
import sys
import time
from pathlib import Path
from typing import Dict, Generator, List, Optional, Tuple

# ─── ANSI colors ──────────────────────────────────────────────────────────────
NO_COLOR = not sys.stdout.isatty() or os.environ.get("NO_COLOR")
RED    = "" if NO_COLOR else "\033[31m"
ORANGE = "" if NO_COLOR else "\033[33m"
YELLOW = "" if NO_COLOR else "\033[93m"
BLUE   = "" if NO_COLOR else "\033[34m"
CYAN   = "" if NO_COLOR else "\033[36m"
BOLD   = "" if NO_COLOR else "\033[1m"
RESET  = "" if NO_COLOR else "\033[0m"

SEV_COLOR = {
    "critical": RED + BOLD,
    "high":     ORANGE + BOLD,
    "medium":   YELLOW,
    "low":      BLUE,
    "info":     CYAN,
}
SEV_ORDER = {"critical": 0, "high": 1, "medium": 2, "low": 3, "info": 4}

# ─── Skip directories ─────────────────────────────────────────────────────────
SKIP_DIRS = {
    "node_modules", ".git", "dist", "build", "target", "vendor",
    ".venv", "venv", "__pycache__", ".next", ".nuxt", ".output",
    ".cache", "coverage", ".nyc_output", "htmlcov", ".pytest_cache",
    ".tox", "eggs", ".eggs", "*.egg-info", "bower_components",
}

SKIP_EXTENSIONS = {
    ".png", ".jpg", ".jpeg", ".gif", ".svg", ".ico", ".webp",
    ".pdf", ".zip", ".tar", ".gz", ".bz2", ".xz", ".7z",
    ".mp4", ".mp3", ".wav", ".avi", ".mov",
    ".woff", ".woff2", ".ttf", ".eot",
    ".pyc", ".pyo", ".class", ".jar", ".war",
    ".exe", ".dll", ".so", ".dylib", ".a",
    ".lock",  # package-lock.json handled separately
}

TEST_PATH_PATTERNS = [
    "test", "tests", "spec", "specs", "__tests__", "fixtures",
    "mocks", "__mocks__", "stubs", "test_helpers",
]

