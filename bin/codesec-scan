def is_test_file(path: Path) -> bool:
    """Heuristic: is this file a test or fixture?"""
    parts = set(p.lower() for p in path.parts)
    for pattern in TEST_PATH_PATTERNS:
        if pattern in parts:
            return True
    name = path.stem.lower()
    return (name.endswith("_test") or name.endswith(".test") or
            name.endswith("_spec") or name.endswith(".spec") or
            name.startswith("test_") or name.startswith("fixture"))


def should_skip_dir(name: str) -> bool:
    return name in SKIP_DIRS or name.startswith(".") and name not in {".github", ".gitlab"}


def read_gitignore(base: Path):
    """Return a list of gitignore patterns (best-effort)."""
    patterns = []
    gi = base / ".gitignore"
    if gi.exists():
        try:
            for line in gi.read_text(errors="ignore").splitlines():
                line = line.strip()
                if line and not line.startswith("#"):
                    patterns.append(line)
        except Exception:
            pass
    return patterns


def matches_gitignore(rel: str, patterns: List[str]) -> bool:
    for pat in patterns:
        if fnmatch.fnmatch(rel, pat) or fnmatch.fnmatch(os.path.basename(rel), pat):
            return True
    return False


def walk_files(base: Path, include_glob: Optional[str], exclude_glob: Optional[str],
               gitignore_patterns: List[str]) -> Generator[Path, None, None]:
    for root, dirs, files in os.walk(base):
        root_path = Path(root)
        dirs[:] = [d for d in dirs if not should_skip_dir(d)]

        for fname in files:
            fpath = root_path / fname
            ext = fpath.suffix.lower()
            if ext in SKIP_EXTENSIONS:
                continue
            rel = str(fpath.relative_to(base))
            if matches_gitignore(rel, gitignore_patterns):
                continue
            if include_glob and not fnmatch.fnmatch(rel, include_glob):
                continue
            if exclude_glob and fnmatch.fnmatch(rel, exclude_glob):
                continue
            yield fpath


def has_inline_ignore(line: str, rule_id: str) -> bool:
    """Check for codesec-ignore: <rule_id> inline comment.

    Supports single IDs and comma-separated lists:
      # codesec-ignore: RULE_A
      # codesec-ignore: RULE_A,RULE_B,RULE_C
    """
    if "codesec-ignore-all" in line:
        return True
    # Extract everything after "codesec-ignore:" and check the list
    for prefix in ("codesec-ignore: ", "codesec-ignore:"):
        idx = line.find(prefix)
        if idx != -1:
            rest = line[idx + len(prefix):]
            # Strip trailing comment/whitespace and split by comma
            ids = [r.strip().rstrip(" -->").strip() for r in rest.split(",")]
            if rule_id in ids:
                return True
    return False


def scan_file(fpath: Path, rules: List[Dict], quick: bool,
              min_severity: str) -> List[Dict]:
    findings = []
    min_order = SEV_ORDER.get(min_severity, 4)

    try:
        content = fpath.read_text(errors="ignore")
    except Exception:
        return findings

    lines = content.splitlines()
    is_test = is_test_file(fpath)
    ext = fpath.suffix.lower()
    fname = fpath.name

    for rule in rules:
        rule_id = rule["rule_id"]
        sev = rule["severity"]

        if SEV_ORDER.get(sev, 4) > min_order:
            continue

        # Skip test-specific relaxations
        if is_test and rule_id in {
            "BACKEND_PYTHON_EVAL", "WEB_EVAL", "BACKEND_PYTHON_EXEC",
            "BACKEND_PYTHON_FLASK_DEBUG", "BACKEND_PYTHON_DJANGO_DEBUG",
            "GENERAL_LOCALHOST_IN_PROD",
        }:
            continue

        # Quick mode: only secrets, eval/exec, SQLi, CMDi
        if quick and rule["category"] not in {
            "secrets", "code-injection", "command-injection", "sql-injection",
        }:
            continue

        # Extension filter
        rule_exts = rule.get("extensions")
        filename_pattern = rule.get("filename_pattern")

        if rule_exts is not None:
            # Check both extension and optional filename_pattern
            ext_match = ext in rule_exts or "" in rule_exts
            fname_match = filename_pattern and re.search(filename_pattern, fname)
            if not ext_match and not fname_match:
                continue

        try:
            compiled = re.compile(rule["pattern"], rule.get("flags", 0))
        except re.error:
            continue

        for lineno, line in enumerate(lines, 1):
            # Check current line AND the preceding line for a codesec-ignore comment
            prev_line = lines[lineno - 2] if lineno >= 2 else ""
            if has_inline_ignore(line, rule_id) or has_inline_ignore(prev_line, rule_id):
                continue
            m = compiled.search(line)
            if m:
                # Skip Stripe publishable keys for OpenAI rule
                if rule_id == "SECRETS_OPENAI_KEY":
                    if "pk_live_" in line or "pk_test_" in line:
                        continue
                    if is_test:
                        continue
                findings.append({
                    "rule_id": rule_id,
                    "severity": sev,
                    "category": rule["category"],
                    "cwe": rule.get("cwe"),
                    "file": str(fpath),
                    "line": lineno,
                    "column": m.start() + 1,
                    "snippet": line.strip()[:200],
                    "message": rule["message"],
                    "fix_hint": rule["fix_hint"],
                })

    return findings


def run_dep_audit(base: Path) -> List[Dict]:
    results = []
    timeout = 30

    def run(cmd, **kwargs):
        try:
            r = subprocess.run(cmd, capture_output=True, text=True, timeout=timeout, **kwargs)
            return r.stdout, r.returncode
        except (subprocess.TimeoutExpired, FileNotFoundError, PermissionError):
            return None, -1

    # npm audit
    if (base / "package.json").exists() and (base / "node_modules").exists():
        out, code = run(["npm", "audit", "--json"], cwd=base)
        if out:
            try:
                data = json.loads(out)
                vulns = data.get("vulnerabilities", {})
                for pkg, info in vulns.items():
                    sev = info.get("severity", "unknown").lower()
                    if sev in ("critical", "high"):
                        results.append({
                            "rule_id": "DEP_NPM_VULN",
                            "severity": sev,
                            "category": "dependency",
                            "cwe": "CWE-1395",
                            "file": str(base / "package.json"),
                            "line": 1,
                            "column": 1,
                            "snippet": f"{pkg}@{info.get('range', '?')}",
                            "message": f"npm vulnerability in {pkg}: {info.get('title', info.get('name', ''))}",
                            "fix_hint": f"Run: npm audit fix. Fixed in: {info.get('fixAvailable', {}).get('version', 'check npm advisory')}",
                        })
            except (json.JSONDecodeError, KeyError):
                pass

    # pip-audit
    if any((base / f).exists() for f in ["requirements.txt", "pyproject.toml", "setup.py"]):
        out, code = run(["pip-audit", "--format", "json"])
        if out:
            try:
                data = json.loads(out)
                for dep in data.get("dependencies", []):
                    for vuln in dep.get("vulns", []):
                        results.append({
                            "rule_id": "DEP_PIP_VULN",
                            "severity": "high",
                            "category": "dependency",
                            "cwe": "CWE-1395",
                            "file": str(base / "requirements.txt"),
                            "line": 1,
                            "column": 1,
                            "snippet": f"{dep.get('name')}=={dep.get('version')}",
                            "message": f"Python vulnerability: {vuln.get('id')} in {dep.get('name')}",
                            "fix_hint": f"Upgrade to {vuln.get('fix_versions', ['?'])[0]} or later.",
                        })
            except (json.JSONDecodeError, KeyError):
                pass

    # cargo audit
    if (base / "Cargo.toml").exists():
        out, code = run(["cargo", "audit", "--json"], cwd=base)
        if out:
            try:
                data = json.loads(out)
                for vuln in data.get("vulnerabilities", {}).get("list", []):
                    results.append({
                        "rule_id": "DEP_CARGO_VULN",
                        "severity": "high",
                        "category": "dependency",
                        "cwe": "CWE-1395",
                        "file": str(base / "Cargo.toml"),
                        "line": 1,
                        "column": 1,
                        "snippet": f"{vuln.get('package', {}).get('name')}",
                        "message": f"Rust advisory {vuln.get('advisory', {}).get('id')}: {vuln.get('advisory', {}).get('title')}",
                        "fix_hint": f"Upgrade to patched version. See: {vuln.get('advisory', {}).get('url')}",
                    })
            except (json.JSONDecodeError, KeyError):
                pass

    return results


def print_human(findings: List[Dict], path: str, elapsed: float):
    if not findings:
        print(f"{BOLD}✓ No findings in {path}{RESET} ({elapsed:.2f}s)")
        return

    by_sev = {}
    for f in findings:
        by_sev.setdefault(f["severity"], []).append(f)

    total = len(findings)
    summary_parts = []
    for sev in ["critical", "high", "medium", "low", "info"]:
        count = len(by_sev.get(sev, []))
        if count:
            color = SEV_COLOR.get(sev, "")
            summary_parts.append(f"{color}{count} {sev}{RESET}")
    print(f"\n{BOLD}Security Scan — {path}{RESET} ({elapsed:.2f}s)")
    print(f"Found {total} finding(s): " + ", ".join(summary_parts))
    print()

    for sev in ["critical", "high", "medium", "low", "info"]:
        sev_findings = by_sev.get(sev, [])
        if not sev_findings:
            continue
        color = SEV_COLOR.get(sev, "")
        label = sev.upper()
        print(f"{color}{'━' * 60}")
        print(f"  {label} ({len(sev_findings)} finding(s)){RESET}")
        print()
        for i, f in enumerate(sev_findings, 1):
            cwe = f.get("cwe") or ""
            print(f"  {color}[{i}] {f['rule_id']}{RESET} {cwe}")
            print(f"      {f['file']}:{f['line']}")
            print(f"      {f['message']}")
            if f.get("snippet"):
                print(f"      {CYAN}→ {f['snippet'][:120]}{RESET}")
            print(f"      Fix: {f['fix_hint']}")
            print()


def main():
    parser = argparse.ArgumentParser(
        description="codesec-scan — Code Security Guardian scanner",
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    parser.add_argument("--path", default=".", help="Directory or file to scan")
    parser.add_argument("--json", action="store_true", dest="json_output",
                        help="Output findings as JSON array")
    parser.add_argument("--quick", action="store_true",
                        help="Quick mode: secrets + code/command/SQL injection only")
    parser.add_argument("--include", metavar="GLOB", help="Only scan files matching this glob")
    parser.add_argument("--exclude", metavar="GLOB", help="Skip files matching this glob")
    parser.add_argument("--no-deps", action="store_true", help="Skip dependency audit")
    parser.add_argument("--severity", default="info",
                        choices=["critical", "high", "medium", "low", "info"],
                        help="Minimum severity to report (default: info)")
    parser.add_argument("--list-rules", action="store_true",
                        help="Print all rule IDs grouped by category and exit")
    args = parser.parse_args()

    if args.list_rules:
        from collections import defaultdict
        by_cat = defaultdict(list)
        for r in RULES:
            by_cat[r["category"]].append(r)
        for cat, rules in sorted(by_cat.items()):
            print(f"\n{BOLD}{cat.upper()}{RESET}")
            for r in sorted(rules, key=lambda x: SEV_ORDER.get(x["severity"], 4)):
                sev = r["severity"]
                color = SEV_COLOR.get(sev, "")
                print(f"  {color}{r['rule_id']:<50}{RESET}  {sev}")
        return

    target = Path(args.path).resolve()
    start = time.time()

    all_findings: List[Dict] = []

    if target.is_file():
        all_findings = scan_file(target, RULES, args.quick, args.severity)
    elif target.is_dir():
        gi_patterns = read_gitignore(target)
        file_count = 0
        for fpath in walk_files(target, args.include, args.exclude, gi_patterns):
            findings = scan_file(fpath, RULES, args.quick, args.severity)
            all_findings.extend(findings)
            file_count += 1

        if not args.quick and not args.no_deps:
            dep_findings = run_dep_audit(target)
            # Filter dep findings by min severity
            min_ord = SEV_ORDER.get(args.severity, 4)
            dep_findings = [f for f in dep_findings
                            if SEV_ORDER.get(f["severity"], 4) <= min_ord]
            all_findings.extend(dep_findings)
    else:
        print(f"Error: {target} does not exist.", file=sys.stderr)
        sys.exit(1)

    elapsed = time.time() - start

    # Sort by severity then file
    all_findings.sort(key=lambda f: (SEV_ORDER.get(f["severity"], 4), f["file"], f["line"]))

    if args.json_output:
        print(json.dumps(all_findings, indent=2))
    else:
        print_human(all_findings, str(target), elapsed)

    # Exit codes
    severities = {f["severity"] for f in all_findings}
    if "critical" in severities:
        sys.exit(3)
    elif "high" in severities:
        sys.exit(2)
    elif "medium" in severities:
        sys.exit(1)
    else:
        sys.exit(0)


if __name__ == "__main__":
    main()
