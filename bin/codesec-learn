#!/usr/bin/env python3
"""
codesec-learn — Feedback ingestion and learning CLI for Code Security Guardian
Stdlib only, Python 3.8+. Author: Reza Sahebozamani <sahebzamanii@gmail.com>
"""

import argparse
import datetime
import hashlib
import json
import os
import sys
from collections import defaultdict
from pathlib import Path
from typing import Any, Dict, List, Optional

# ─── Plugin root detection ─────────────────────────────────────────────────────
def plugin_root() -> Path:
    env = os.environ.get("CLAUDE_PLUGIN_ROOT")
    if env:
        return Path(env)
    p = Path(__file__).resolve().parent.parent
    if (p / ".claude-plugin" / "plugin.json").exists():
        return p
    return Path.cwd()


ROOT = plugin_root()
MEMORY_DIR = ROOT / "memory"
FEEDBACK_LOG = MEMORY_DIR / "feedback-log.jsonl"
FINDINGS_LOG = MEMORY_DIR / "findings-log.jsonl"
RESEARCH_CACHE = MEMORY_DIR / "research-cache.jsonl"
FP_PATTERNS = MEMORY_DIR / "false-positive-patterns.yaml"
PROJECT_CONTEXT = MEMORY_DIR / "project-context.yaml"
APPLIED_LOG = MEMORY_DIR / "applied-proposals.jsonl"
RULES_LOCAL = ROOT / "rules" / "local"
CONFIG_FILE = ROOT / "config" / "settings.yaml"

ANSI = not (os.environ.get("NO_COLOR") or not sys.stdout.isatty())
BOLD   = "\033[1m" if ANSI else ""
GREEN  = "\033[32m" if ANSI else ""
YELLOW = "\033[93m" if ANSI else ""
CYAN   = "\033[36m" if ANSI else ""
RESET  = "\033[0m" if ANSI else ""


# ─── Helpers ──────────────────────────────────────────────────────────────────

def sha256(s: str) -> str:
    return "sha256:" + hashlib.sha256(s.encode()).hexdigest()[:16]


def now_iso() -> str:
    return datetime.datetime.utcnow().strftime("%Y-%m-%dT%H:%M:%SZ")


def load_jsonl(path: Path) -> List[Dict]:
    if not path.exists():
        return []
    entries = []
    for line in path.read_text(errors="ignore").splitlines():
        line = line.strip()
        if line:
            try:
                entries.append(json.loads(line))
            except json.JSONDecodeError:
                pass
    return entries


def append_jsonl(path: Path, entry: Dict):
    MEMORY_DIR.mkdir(parents=True, exist_ok=True)
    with open(path, "a", encoding="utf-8") as f:
        f.write(json.dumps(entry) + "\n")


def load_config() -> Dict:
    if CONFIG_FILE.exists():
        try:
            # Simple key: value config reader (no full YAML needed)
            config = {"learning": {}, "privacy": {}}
            for line in CONFIG_FILE.read_text(errors="ignore").splitlines():
                stripped = line.strip()
                if stripped.startswith("#") or ":" not in stripped:
                    continue
            return config
        except Exception:
            pass
    return {"learning": {}, "privacy": {}}


def get_min_occurrences() -> int:
    cfg = load_config()
    return (cfg.get("learning") or {}).get("min_occurrences_for_proposal", 5)


def get_dismiss_threshold() -> float:
    cfg = load_config()
    return (cfg.get("learning") or {}).get("dismiss_rate_threshold_for_narrowing", 0.7)


def load_fp_patterns() -> List[Dict]:
    """Load memory/false-positive-patterns.yaml (minimal parser)."""
    if not FP_PATTERNS.exists():
        return []
    try:
        content = FP_PATTERNS.read_text(errors="ignore")
        patterns = []
        current = None
        for line in content.splitlines():
            stripped = line.strip()
            if stripped.startswith("- rule_id:"):
                if current:
                    patterns.append(current)
                current = {"rule_id": stripped.split(":", 1)[1].strip().strip("'")}
            elif current and ":" in stripped and not stripped.startswith("#"):
                k, v = stripped.split(":", 1)
                current[k.strip()] = v.strip().strip("'\"")
        if current:
            patterns.append(current)
        return patterns
    except Exception:
        return []


def save_fp_patterns(patterns: List[Dict]):
    MEMORY_DIR.mkdir(parents=True, exist_ok=True)
    lines = ["# False positive suppression patterns — auto-managed by codesec-learn.",
             "# Each entry suppresses a specific rule in a specific file (or globally).",
             "",
             "patterns:"]
    for p in patterns:
        first = True
        for k, v in p.items():
            prefix = "  - " if first else "    "
            first = False
            lines.append(f"{prefix}{k}: {v}")
    FP_PATTERNS.write_text("\n".join(lines) + "\n")


# ─── Commands ─────────────────────────────────────────────────────────────────

def cmd_record(args):
    """Record a single feedback decision."""
    decision = args.decision
    if decision not in ("accept", "dismiss", "fix", "skip"):
        print(f"Invalid decision '{decision}'. Must be: accept, dismiss, fix, skip", file=sys.stderr)
        sys.exit(1)

    entry = {
        "timestamp": now_iso(),
        "rule_id": args.finding_id,
        "file_hash": "sha256:manual",
        "snippet_hash": "sha256:manual",
        "decision": decision,
        "reason": args.reason or "",
        "project_id": _get_project_id(),
        "scan_id": "sha256:manual",
    }
    append_jsonl(FEEDBACK_LOG, entry)
    print(f"Recorded: {args.finding_id} → {decision}" + (f" ({args.reason})" if args.reason else ""))


def _get_project_id() -> str:
    try:
        import subprocess
        result = subprocess.run(
            ["git", "remote", "get-url", "origin"],
            capture_output=True, text=True, timeout=5
        )
        if result.returncode == 0:
            return sha256(result.stdout.strip())
    except Exception:
        pass
    return "sha256:unknown"


def cmd_analyze(args):
    """Analyze feedback patterns and print statistics."""
    entries = load_jsonl(FEEDBACK_LOG)
    if not entries:
        print("No feedback recorded yet.")
        print("Run a scan and respond to finding prompts, then run: codesec-learn analyze")
        return

    min_occ = get_min_occurrences()
    dismiss_threshold = get_dismiss_threshold()

    # Cluster by rule_id
    by_rule: Dict[str, List[Dict]] = defaultdict(list)
    for e in entries:
        rid = e.get("rule_id")
        if rid:
            by_rule[rid].append(e)

    print(f"\n{BOLD}Feedback Analysis{RESET}")
    print(f"  Total entries:    {len(entries)}")
    print(f"  Rules with data:  {len(by_rule)}")

    # Counts
    decisions = defaultdict(int)
    for e in entries:
        decisions[e.get("decision", "unknown")] += 1
    for d, c in sorted(decisions.items(), key=lambda x: -x[1]):
        print(f"  {d:<12}  {c}")

    print(f"\n{BOLD}Per-Rule Summary (rules with ≥{min_occ} occurrences):{RESET}")
    proposals = []

    for rule_id, rule_entries in sorted(by_rule.items()):
        if len(rule_entries) < min_occ:
            continue
        total = len(rule_entries)
        accept_count = sum(1 for e in rule_entries if e.get("decision") == "accept")
        dismiss_count = sum(1 for e in rule_entries if e.get("decision") in ("dismiss", "skip"))
        fix_count = sum(1 for e in rule_entries if e.get("decision") == "fix")
        dismiss_rate = dismiss_count / total if total else 0
        accept_rate = accept_count / total if total else 0

        # Cluster dismiss reasons
        reasons = [e.get("reason", "") for e in rule_entries if e.get("decision") in ("dismiss", "skip") and e.get("reason")]
        reason_counts: Dict[str, int] = defaultdict(int)
        for r in reasons:
            reason_counts[r] += 1
        top_reasons = sorted(reason_counts.items(), key=lambda x: -x[1])[:3]

        bar = "█" * int(dismiss_rate * 10) + "░" * (10 - int(dismiss_rate * 10))
        flag = f"{YELLOW}⚠ high FP{RESET}" if dismiss_rate >= dismiss_threshold else ""
        print(f"\n  {BOLD}{rule_id}{RESET}")
        print(f"    Occurrences: {total}  Accept: {accept_count}  Dismiss: {dismiss_count}  Fix: {fix_count}")
        print(f"    Dismiss rate: [{bar}] {dismiss_rate:.0%}  {flag}")
        if top_reasons:
            print(f"    Top dismiss reasons:")
            for reason, cnt in top_reasons:
                print(f"      ({cnt}x) {reason}")

        # Generate proposal if needed
        if dismiss_rate >= dismiss_threshold and total >= min_occ:
            proposals.append({
                "id": len(proposals) + 1,
                "type": "add-fp-pattern" if top_reasons else "lower-severity",
                "rule_id": rule_id,
                "evidence": {
                    "total": total,
                    "dismiss_rate": round(dismiss_rate, 2),
                    "top_reasons": [r for r, _ in top_reasons],
                }
            })
        elif accept_rate >= 0.9 and total >= 10:
            proposals.append({
                "id": len(proposals) + 1,
                "type": "elevate-confidence",
                "rule_id": rule_id,
                "evidence": {
                    "total": total,
                    "accept_rate": round(accept_rate, 2),
                }
            })

    if proposals:
        print(f"\n{BOLD}Proposals generated: {len(proposals)}{RESET}")
        print("Run `codesec-learn propose-suppressions` to see and apply them.")
    else:
        print(f"\nNo proposals at this time (need ≥{min_occ} occurrences per rule with dismiss rate ≥{dismiss_threshold:.0%})")

    return proposals


def cmd_propose_suppressions(args):
    """Generate and display suppression proposals."""
    entries = load_jsonl(FEEDBACK_LOG)
    if not entries:
        print("No feedback data.")
        return

    min_occ = get_min_occurrences()
    dismiss_threshold = get_dismiss_threshold()

    by_rule: Dict[str, List[Dict]] = defaultdict(list)
    for e in entries:
        rid = e.get("rule_id")
        if rid:
            by_rule[rid].append(e)

    proposals = []
    for rule_id, rule_entries in sorted(by_rule.items()):
        if len(rule_entries) < min_occ:
            continue
        total = len(rule_entries)
        dismiss_count = sum(1 for e in rule_entries if e.get("decision") in ("dismiss", "skip"))
        dismiss_rate = dismiss_count / total if total else 0

        if dismiss_rate < dismiss_threshold:
            continue

        reasons = [e.get("reason", "") for e in rule_entries if e.get("decision") in ("dismiss", "skip") and e.get("reason")]
        reason_counts: Dict[str, int] = defaultdict(int)
        for r in reasons:
            reason_counts[r] += 1
        top_reasons = sorted(reason_counts.items(), key=lambda x: -x[1])[:3]

        prop_id = len(proposals) + 1
        print(f"\n{BOLD}[{prop_id}] Narrow {rule_id}{RESET}")
        print(f"     Dismiss rate: {dismiss_rate:.0%} ({dismiss_count}/{total})")
        if top_reasons:
            print(f"     Top reasons: {', '.join(r for r, _ in top_reasons)}")
        print(f"     Proposed: Add false-positive pattern to memory/false-positive-patterns.yaml")
        if top_reasons:
            best_reason, _ = top_reasons[0]
            print(f"     Preview entry:")
            print(f"       - rule_id: {rule_id}")
            print(f"         path_pattern: '*'")
            print(f"         reason: '{best_reason}'")
            print(f"         added: {datetime.date.today().isoformat()}")
            print(f"         source: auto-learned")

        proposals.append({
            "id": prop_id,
            "type": "add-fp-pattern",
            "rule_id": rule_id,
            "dismiss_rate": dismiss_rate,
            "reasons": [r for r, _ in top_reasons],
        })

    if not proposals:
        print(f"No suppression proposals at this time.")
        return

    print(f"\n{BOLD}Apply with: codesec-learn apply --proposal <N>{RESET}")
    print(f"Apply all:  codesec-learn apply --proposal all")

    # Cache proposals to a temp file for apply command
    temp_proposals = ROOT / "memory" / "_pending-proposals.json"
    temp_proposals.write_text(json.dumps(proposals, indent=2))


def cmd_apply(args):
    """Apply a proposal."""
    proposals_file = ROOT / "memory" / "_pending-proposals.json"
    if not proposals_file.exists():
        print("No pending proposals. Run: codesec-learn propose-suppressions")
        return

    proposals = json.loads(proposals_file.read_text())
    target = args.proposal.strip()

    selected = []
    if target.lower() == "all":
        selected = proposals
    else:
        for part in target.split(","):
            part = part.strip()
            try:
                pid = int(part)
                prop = next((p for p in proposals if p["id"] == pid), None)
                if prop:
                    selected.append(prop)
                else:
                    print(f"Proposal {pid} not found.")
            except ValueError:
                print(f"Invalid proposal ID: {part}")

    if not selected:
        print("No proposals selected.")
        return

    existing_patterns = load_fp_patterns()

    for prop in selected:
        ptype = prop.get("type")
        rule_id = prop.get("rule_id")

        if ptype == "add-fp-pattern":
            reasons = prop.get("reasons", [""])
            reason = reasons[0] if reasons else "auto-learned"
            new_pattern = {
                "rule_id": rule_id,
                "path_pattern": "*",
                "reason": reason,
                "added": datetime.date.today().isoformat(),
                "source": "auto-learned",
            }
            existing_patterns.append(new_pattern)
            print(f"[{prop['id']}] Added FP pattern for {rule_id}: '{reason}'")

        elif ptype == "elevate-confidence":
            _write_local_override_confidence(rule_id, "high")
            print(f"[{prop['id']}] Elevated confidence for {rule_id} to high")

        # Log the application
        append_jsonl(APPLIED_LOG, {
            "timestamp": now_iso(),
            "proposal_id": prop["id"],
            "type": ptype,
            "rule_id": rule_id,
        })

    save_fp_patterns(existing_patterns)
    print(f"\nApplied {len(selected)} proposal(s). Changes written to memory/false-positive-patterns.yaml")


def _write_local_override_confidence(rule_id: str, confidence: str):
    """Write a confidence override to rules/local/overrides.yaml."""
    RULES_LOCAL.mkdir(parents=True, exist_ok=True)
    override_file = RULES_LOCAL / "overrides.yaml"
    # Simple: append an override entry
    content = f"\n  - id: {rule_id}\n    confidence: {confidence}\n    source: local\n"
    if override_file.exists():
        existing = override_file.read_text()
        if "rules:" not in existing:
            existing = "rules:\n" + existing
        override_file.write_text(existing + content)
    else:
        override_file.write_text("rules:\n" + content)


def cmd_propose_rules(args):
    """Suggest new rules based on missed findings (manual accepts with no matching rule)."""
    entries = load_jsonl(FEEDBACK_LOG)
    manual_accepts = [e for e in entries if e.get("decision") == "accept" and e.get("reason")]

    if not manual_accepts:
        print("No manual accept feedback with reasons found.")
        print("To suggest a missed rule, run: codesec-learn record --finding-id MANUAL --decision accept --reason 'describe what was missed'")
        return

    print(f"\n{BOLD}Missed findings reported by user ({len(manual_accepts)}):{RESET}")
    for e in manual_accepts:
        print(f"  {e['timestamp']}: {e.get('reason')}")

    print(f"\nTo turn these into rules, run: /code-security-guardian:security-research")
    print("Then ask: 'Write a rule for: <description>'")


def cmd_export(args):
    """Export anonymized feedback for sharing."""
    entries = load_jsonl(FEEDBACK_LOG)
    if not entries:
        print("No feedback to export.")
        return

    if args.plain:
        # Show what the export contains
        print("Export preview (this is what would be shared):")
        for e in entries[:10]:
            print(json.dumps({k: v for k, v in e.items() if k != "scan_id"}, indent=2))
        if len(entries) > 10:
            print(f"... and {len(entries) - 10} more entries")
        print("\nNote: file paths and snippets are HASHED — no raw source code is included.")
    else:
        # Write to export file
        export_file = ROOT / f"codesec-feedback-export-{datetime.date.today().isoformat()}.jsonl"
        export_file.write_text("\n".join(json.dumps(e) for e in entries))
        print(f"Exported {len(entries)} entries to {export_file}")
        print("Review with: codesec-learn export --plain")


def cmd_import_feedback(args):
    """Merge anonymized feedback from a teammate."""
    src = Path(args.file)
    if not src.exists():
        print(f"File not found: {src}", file=sys.stderr)
        sys.exit(1)

    imported = 0
    existing = load_jsonl(FEEDBACK_LOG)
    existing_hashes = {json.dumps(e, sort_keys=True) for e in existing}

    for line in src.read_text(errors="ignore").splitlines():
        line = line.strip()
        if not line:
            continue
        try:
            entry = json.loads(line)
            entry_str = json.dumps(entry, sort_keys=True)
            if entry_str not in existing_hashes:
                append_jsonl(FEEDBACK_LOG, entry)
                imported += 1
        except json.JSONDecodeError:
            pass

    print(f"Imported {imported} new entries from {src}")


# ─── Main ──────────────────────────────────────────────────────────────────────

def main():
    parser = argparse.ArgumentParser(
        prog="codesec-learn",
        description="Feedback ingestion and learning CLI for Code Security Guardian"
    )
    sub = parser.add_subparsers(dest="command")

    p_record = sub.add_parser("record", help="Record a feedback decision")
    p_record.add_argument("--finding-id", required=True, metavar="RULE_ID")
    p_record.add_argument("--decision", required=True,
                          choices=["accept", "dismiss", "fix", "skip"])
    p_record.add_argument("--reason", metavar="TEXT", default="")

    sub.add_parser("analyze", help="Summarize feedback patterns")
    sub.add_parser("propose-suppressions", help="Generate FP suppression proposals")
    sub.add_parser("propose-rules", help="List missed findings for new rule proposals")

    p_apply = sub.add_parser("apply", help="Apply a proposal")
    p_apply.add_argument("--proposal", required=True,
                         metavar="N|all", help="Proposal number(s) or 'all'")

    p_export = sub.add_parser("export", help="Export anonymized feedback")
    p_export.add_argument("--plain", action="store_true", help="Preview in terminal")

    p_import = sub.add_parser("import", help="Import teammate's anonymized feedback")
    p_import.add_argument("file")

    args = parser.parse_args()

    commands = {
        "record":               cmd_record,
        "analyze":              cmd_analyze,
        "propose-suppressions": cmd_propose_suppressions,
        "propose-rules":        cmd_propose_rules,
        "apply":                cmd_apply,
        "export":               cmd_export,
        "import":               cmd_import_feedback,
    }

    if args.command not in commands:
        parser.print_help()
        sys.exit(1)

    commands[args.command](args)


if __name__ == "__main__":
    main()
